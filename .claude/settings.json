{
  "$schema": "https://claude.ai/schema/settings.json",
  "project": {
    "name": "Echoelmusic",
    "description": "Bio-reactive audio-visual production suite",
    "version": "10000.2",
    "phase": "ULTIMATE RALPH WIGGUM LOOP MODE"
  },
  "safety": {
    "enabled": true,
    "rules": [
      {
        "pattern": "git reset --hard",
        "action": "block",
        "reason": "Protects uncommitted work and biometric test data"
      },
      {
        "pattern": "git push --force",
        "action": "block",
        "reason": "Production branch protection - use PRs"
      },
      {
        "pattern": "git push --force-with-lease",
        "action": "block",
        "reason": "Force push blocked - use regular push"
      },
      {
        "pattern": "git clean -f",
        "action": "block",
        "reason": "Protects untracked files from deletion"
      },
      {
        "pattern": "git checkout -- .",
        "action": "block",
        "reason": "Discards all uncommitted changes - use git stash instead"
      },
      {
        "pattern": "git branch -D",
        "action": "warn",
        "reason": "Force-deleting branch - confirm intent"
      },
      {
        "pattern": "rm -rf Sources/",
        "action": "block",
        "reason": "Core Swift source protection"
      },
      {
        "pattern": "rm -rf android/",
        "action": "block",
        "reason": "Android build protection"
      },
      {
        "pattern": "rm -rf Tests/",
        "action": "block",
        "reason": "Test suite protection (1060+ tests)"
      },
      {
        "pattern": "rm -rf docs/",
        "action": "block",
        "reason": "Website/WebApp protection"
      },
      {
        "pattern": "rm -rf .claude/",
        "action": "block",
        "reason": "Claude Code configuration protection"
      },
      {
        "pattern": "rm -rf memory/",
        "action": "block",
        "reason": "Persistent memory protection"
      },
      {
        "pattern": "DROP TABLE",
        "action": "block",
        "reason": "Database protection"
      },
      {
        "pattern": "DELETE FROM",
        "action": "warn",
        "reason": "Potential data loss - confirm intent"
      },
      {
        "pattern": "curl | sh",
        "action": "block",
        "reason": "Pipe-to-shell blocked - download and inspect first"
      },
      {
        "pattern": "curl | bash",
        "action": "block",
        "reason": "Pipe-to-shell blocked - download and inspect first"
      },
      {
        "pattern": "eval $(",
        "action": "warn",
        "reason": "Dynamic eval - verify command is safe"
      }
    ],
    "allowedDestructive": [
      "rm -rf build/",
      "rm -rf .build/",
      "rm -rf DerivedData/",
      "rm -rf node_modules/",
      "rm -rf dist/"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "workflow": {
    "branchPrefix": "claude/",
    "commitStyle": "conventional",
    "prRequired": true,
    "testBeforeCommit": true,
    "lintBeforeCommit": false
  },
  "context": {
    "maxTokens": 200000,
    "forkOnComplexTasks": true,
    "preserveAcrossSessions": [
      "architecture-decisions",
      "phase-progress",
      "known-issues"
    ]
  },
  "platforms": {
    "primary": ["iOS", "macOS", "visionOS"],
    "secondary": ["Android", "Windows", "Linux"],
    "web": ["PWA", "WebApp"]
  },
  "engines": {
    "audio": ["AudioEngine", "SpatialAudioEngine", "LoopEngine"],
    "visual": ["PhotonicsVisualizationEngine", "CymaticsRenderer"],
    "biofeedback": ["HealthKitManager", "BioParameterMapper", "RealTimeHealthKitEngine"],
    "collaboration": ["CollaborationSyncEngine", "GroupCoherenceEngine"],
    "wellness": ["CircadianRhythmEngine", "EvidenceBasedHRVTraining", "BioModulator"],
    "production": ["StreamEngine", "VideoProcessingEngine", "CreativeStudioEngine"]
  }
}
